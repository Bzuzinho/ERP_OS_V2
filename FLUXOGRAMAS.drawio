        <mxCell id="step5" value="5. render()&#xa;chamado&#xa;Nova renderização" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4DA8FF;fontColor=#FFFFFF;fontStyle=1" vertex="1" parent="1">
