        <mxCell id="step2" value="2. render()&#xa;Renderiza view&#xa;baseado em state.tab" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4DA8FF;fontColor=#FFFFFF;fontStyle=1" vertex="1" parent="1">
