        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=2;endArrow=classic;" edge="1" source="step2" target="step3" parent="1"/>

        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=2;endArrow=classic;" edge="1" source="step3" target="step4" parent="1"/>

        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=2;endArrow=classic;" edge="1" source="step4" target="step5" parent="1"/>

        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=2;endArrow=classic;" edge="1" source="step5" target="step6" parent="1"/>

        <!-- Loop back -->
        <mxCell id="eloop" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#B57BFF;strokeWidth=2;endArrow=classic;" edge="1" source="step6" target="step2" parent="1">
