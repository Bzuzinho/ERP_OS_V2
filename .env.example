APP_NAME="Junta Operacional"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.railway.app

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── Base de dados ─────────────────────────────────────────────────────────────
# Railway injeta DATABASE_URL automaticamente quando adicionas o PostgreSQL add-on.
# Não precisas de definir DB_* manualmente — o config/database.php lê DATABASE_URL.
# Se quiseres definir manualmente (opcional):
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=require

# ── Sessão & Cache ────────────────────────────────────────────────────────────
# "cookie" não necessita de base de dados; "database" mais seguro para produção
SESSION_DRIVER=cookie
SESSION_LIFETIME=480
CACHE_STORE=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# ── Email (opcional) ──────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@juntaos.pt"
MAIL_FROM_NAME="${APP_NAME}"

# ── Vite ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
